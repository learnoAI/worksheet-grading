# Frontend (Next.js)

# Backend API base URL (include `/api`)
NEXT_PUBLIC_API_URL=http://localhost:5100/api

# Optional analytics (PostHog)
# NEXT_PUBLIC_POSTHOG_KEY=REPLACE_ME
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Cloudflare deployment (put in .env.local, not .env)
# Required for `npm run cf:deploy` and `npm run cf:preview`
# CLOUDFLARE_ACCOUNT_ID=your_account_id_here

