# Backend (DigitalOcean App Platform)
NODE_ENV=production

# DigitalOcean injects `PORT` for web services. For local dev you can also set `APP_PORT`.
PORT=5100
# APP_PORT=5100

# Postgres (Prisma)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public

# Auth
JWT_SECRET=REPLACE_ME

# CORS
# Comma-separated list of allowed origins, or "*" to allow all.
CORS_ORIGINS=*

# Optional logging
LOG_LEVEL=info
# MONGO_URL=mongodb+srv://...

# Optional PostHog server-side telemetry for grading pipeline events
# (If omitted, PostHog capture is disabled on backend.)
# POSTHOG_API_KEY=phc_xxx
# POSTHOG_HOST=https://us.i.posthog.com

# Optional backend diagnostics for slow/error requests and grading persistence
REQUEST_DIAGNOSTICS_ENABLED=true
REQUEST_DIAGNOSTICS_SLOW_MS=1500
GRADING_PERSISTENCE_SLOW_MS=750

# Queue mode
# - inline: grade inside the backend request (dev only)
# - cloudflare: enqueue-only backend; grading runs asynchronously
GRADING_QUEUE_MODE=cloudflare

# Disable legacy Bull queue (and Redis requirement) in Cloudflare queue mode.
ENABLE_LEGACY_BULL_QUEUE=false
# REDIS_URL=redis://localhost:6379

# Cloudflare API (backend publishes queue messages)
CF_ACCOUNT_ID=REPLACE_ME
CF_API_TOKEN=REPLACE_ME
# Cloudflare Queues identifier for REST API calls.
# In most setups this is the queue ID (UUID) shown in the Cloudflare dashboard / API.
# (Some API tooling may also accept the queue name; if in doubt, use the UUID.)
CF_QUEUE_ID=REPLACE_ME
CF_API_BASE_URL=https://api.cloudflare.com/client/v4
# CF_CONSUMER_NAME=grading-worker

# Shared secret for Cloudflare Worker -> backend internal endpoints (/internal/grading-worker/*)
GRADING_WORKER_TOKEN=REPLACE_ME

# DO pull-worker is disabled when Cloudflare Worker is the queue consumer.
# (Only enable this if you're intentionally using the backend pull-consumer path.)
GRADING_PULL_WORKER_ENABLED=false

# Dispatch/recovery tuning (backend)
GRADING_DISPATCH_LOOP_INTERVAL_MS=5000
# Keep true unless you are running a dedicated dispatch process and want it disabled on web.
GRADING_DISPATCH_LOOP_ON_WEB=true
GRADING_HEARTBEAT_INTERVAL_MS=60000
GRADING_STALE_PROCESSING_MS=1200000
GRADING_FAST_MAX_PAGES=4

# Object storage
# New uploads should be R2, but keep S3 creds configured for old images still referenced in DB.
OBJECT_STORAGE_PROVIDER=r2

# R2 (S3-compatible API)
R2_ACCOUNT_ID=REPLACE_ME
R2_ACCESS_KEY_ID=REPLACE_ME
R2_SECRET_ACCESS_KEY=REPLACE_ME
R2_BUCKET_NAME=worksheet-grading-files
# R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# R2_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev

# Legacy S3 (keep for old images)
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=worksheet-images

# Legacy python grader (only used when GRADING_QUEUE_MODE=inline or the backend pull-worker is enabled)
PYTHON_API_URL=https://REPLACE_ME

# Optional python rate limiter (only affects python path)
GRADING_MAX_CONCURRENT=5
GRADING_MIN_TIME_MS=200
