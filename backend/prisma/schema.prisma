generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String          @id @default(uuid())
  username          String          @unique
  password          String
  name              String
  tokenNumber       String?         @unique
  role              UserRole
  isArchived        Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  adminSchools      AdminSchool[]
  notifications     Notification[]
  studentClasses    StudentClass[]
  teacherClasses    TeacherClass[]
  studentSchools    StudentSchool[]
  worksheets        Worksheet[]     @relation("SubmittedBy")
  studentWorksheets Worksheet[]     @relation("StudentWorksheets")
  teacherSchools    TeacherSchool[]
  studentGradingJobs GradingJob[]   @relation("StudentGradingJobs")
  teacherGradingJobs GradingJob[]   @relation("TeacherGradingJobs")
  skillMastery        StudentSkillMastery[]
  generatedWorksheets GeneratedWorksheet[]
}

model School {
  id             String          @id @default(uuid())
  name           String
  isArchived     Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  clusterId      String?
  adminSchools   AdminSchool[]
  classes        Class[]
  cluster        Cluster?        @relation(fields: [clusterId], references: [id])
  teacherSchools TeacherSchool[]
  studentSchools StudentSchool[]
}

model Cluster {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  schools   School[]
}

model Class {
  id             String         @id @default(uuid())
  name           String
  schoolId       String
  isArchived     Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  school         School         @relation(fields: [schoolId], references: [id])
  studentClasses StudentClass[]
  teacherClasses TeacherClass[]
  worksheets     Worksheet[]
  gradingJobs    GradingJob[]
  worksheetBatches WorksheetBatch[]
}

model TeacherClass {
  teacherId String
  classId   String
  createdAt DateTime @default(now())
  class     Class    @relation(fields: [classId], references: [id])
  teacher   User     @relation(fields: [teacherId], references: [id])

  @@id([teacherId, classId])
}

model StudentClass {
  studentId String
  classId   String
  createdAt DateTime @default(now())
  class     Class    @relation(fields: [classId], references: [id])
  student   User     @relation(fields: [studentId], references: [id])

  @@id([studentId, classId])
}

model TeacherSchool {
  teacherId String
  schoolId  String
  createdAt DateTime @default(now())
  teacher   User     @relation(fields: [teacherId], references: [id])
  school    School   @relation(fields: [schoolId], references: [id])

  @@id([teacherId, schoolId])
}

model AdminSchool {
  adminId   String
  schoolId  String
  createdAt DateTime @default(now())
  admin     User     @relation(fields: [adminId], references: [id])
  school    School   @relation(fields: [schoolId], references: [id])

  @@id([adminId, schoolId])
}

model StudentSchool {
  studentId String
  schoolId  String
  createdAt DateTime @default(now())
  student   User     @relation(fields: [studentId], references: [id])
  school    School   @relation(fields: [schoolId], references: [id])

  @@id([studentId, schoolId])
}

model MainTopic {
  id         String      @id @default(uuid())
  name       String      @unique
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  mathSkills MathSkill[]
}

model MathSkill {
  id                 String                      @id @default(uuid())
  name               String
  description        String?
  mainTopicId        String?
  mainTopic          MainTopic?                  @relation(fields: [mainTopicId], references: [id])
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  worksheets         WorksheetTemplateQuestion[]
  worksheetSkillMaps WorksheetSkillMap[]
  studentMastery     StudentSkillMastery[]
  questionBank       QuestionBank[]

  @@index([mainTopicId])
  @@unique([name, mainTopicId], name: "math_skill_name_main_topic_unique")
}

model WorksheetSkillMap {
  id             String    @id @default(uuid())
  worksheetNumber Int      @unique
  mathSkillId    String
  isTest         Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  mathSkill      MathSkill @relation(fields: [mathSkillId], references: [id])

  @@index([mathSkillId])
  @@index([isTest])
}

model WorksheetTemplate {
  id              String                      @id @default(uuid())
  worksheetNumber Int?                        @unique
  worksheetImages WorksheetTemplateImage[]
  questions       WorksheetTemplateQuestion[]
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  worksheets      Worksheet[]
}

model WorksheetTemplateImage {
  id                  String            @id @default(uuid())
  imageUrl            String
  pageNumber          Int
  worksheetTemplateId String
  worksheetTemplate   WorksheetTemplate @relation(fields: [worksheetTemplateId], references: [id])
}

model WorksheetTemplateQuestion {
  id                  String              @id @default(uuid())
  question            String
  worksheetTemplateId String
  worksheetTemplates  WorksheetTemplate[]
  answer              String?
  skills              MathSkill[]
  outOf               Float?              @default(1)
  worksheetQuestions  WorksheetQuestion[]
}

model WorksheetQuestion {
  id               String                    @id @default(uuid())
  question         String
  worksheetId      String
  worksheet        Worksheet                 @relation(fields: [worksheetId], references: [id])
  questionId       String
  templateQuestion WorksheetTemplateQuestion @relation(fields: [questionId], references: [id])
}

model Worksheet {
  id                   String              @id @default(uuid())
  notes                String?
  status               ProcessingStatus    @default(PENDING)
  grade                Float?
  outOf                Float?              @default(40)
  submittedById        String
  submittedOn          DateTime?
  classId              String
  studentId            String?
  student              User?               @relation("StudentWorksheets", fields: [studentId], references: [id])
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  class                Class               @relation(fields: [classId], references: [id])
  submittedBy          User                @relation("SubmittedBy", fields: [submittedById], references: [id])
  images               WorksheetImage[]
  templateId           String?
  template             WorksheetTemplate?  @relation(fields: [templateId], references: [id])
  worksheetQuestions   WorksheetQuestion[]
  isAbsent             Boolean             @default(false)
  isRepeated           Boolean             @default(false)
  isCorrectGrade       Boolean             @default(false)
  isIncorrectGrade     Boolean             @default(false)  // Flag to mark if teacher thinks grade is incorrect
  mongoDbId            String?             @unique
  gradingDetails       Json?               // Store the detailed grading information from AI
  wrongQuestionNumbers String?             // Comma-separated wrong question numbers
  adminComments        String?             // Administrative comments for incorrect grading review
  worksheetNumber      Int                 @default(0)  // Direct worksheet number storage (0 = absent/unassigned)
  practiceLog          SkillPracticeLog[]

  // Performance indexes for analytics queries
  @@index([createdAt])
  @@index([submittedOn])
  @@index([classId, createdAt])
  @@index([studentId, submittedOn])
  @@index([isAbsent, createdAt])
  @@index([isRepeated, createdAt])
  @@index([grade, outOf, isAbsent])
  @@unique([studentId, classId, worksheetNumber, submittedOn], name: "unique_worksheet_per_student_day")
}

model WorksheetImage {
  id          String    @id @default(uuid())
  imageUrl    String
  pageNumber  Int
  worksheetId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  worksheet   Worksheet @relation(fields: [worksheetId], references: [id], onDelete: Cascade)

  @@index([worksheetId, pageNumber])
}

model Notification {
  id        String             @id @default(uuid())
  message   String
  userId    String
  status    NotificationStatus @default(UNREAD)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  user      User               @relation(fields: [userId], references: [id])
}

enum UserRole {
  TEACHER
  STUDENT
  ADMIN
  SUPERADMIN
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum NotificationStatus {
  READ
  UNREAD
}

enum StorageProvider {
  S3
  R2
}

enum GradingJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum MasteryLevel {
  NOT_STARTED
  ATTEMPTED
  FAMILIAR
  PROFICIENT
  MASTERED
}

model GradingJob {
  id              String           @id @default(uuid())
  studentId       String
  student         User             @relation("StudentGradingJobs", fields: [studentId], references: [id])
  studentName     String           // Denormalized for quick display
  worksheetNumber Int
  worksheetName   String?
  tokenNo         String?
  isRepeated      Boolean          @default(false)
  classId         String
  class           Class            @relation(fields: [classId], references: [id])
  teacherId       String
  teacher         User             @relation("TeacherGradingJobs", fields: [teacherId], references: [id])
  status          GradingJobStatus @default(QUEUED)
  worksheetId     String?          // Set after worksheet created/updated
  errorMessage    String?
  dispatchError   String?
  leaseId         String?
  attemptCount    Int              @default(0)
  enqueuedAt      DateTime?
  startedAt       DateTime?
  lastHeartbeatAt DateTime?
  lastErrorAt     DateTime?
  submittedOn     DateTime         // The date the worksheet was submitted for
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  completedAt     DateTime?
  images          GradingJobImage[]

  @@index([teacherId, status])
  @@index([teacherId, createdAt])
  @@index([classId, createdAt])
  @@index([status, createdAt])
  @@index([status, enqueuedAt])
  @@index([status, lastHeartbeatAt])
}

model GradingJobImage {
  id           String     @id @default(uuid())
  gradingJobId String
  gradingJob   GradingJob @relation(fields: [gradingJobId], references: [id], onDelete: Cascade)
  storageProvider StorageProvider @default(S3)
  imageUrl     String
  s3Key        String
  pageNumber   Int
  mimeType     String
  createdAt    DateTime   @default(now())

  @@index([gradingJobId, pageNumber])
}

model StudentSkillMastery {
  id             String       @id @default(uuid())
  studentId      String
  student        User         @relation(fields: [studentId], references: [id])
  mathSkillId    String
  mathSkill      MathSkill    @relation(fields: [mathSkillId], references: [id])
  masteryLevel   MasteryLevel @default(NOT_STARTED)
  stability      Float        @default(1.0)
  difficulty     Float        @default(5.0)
  lastPracticeAt DateTime?
  lastScore      Float?
  practiceCount  Int          @default(0)
  testCount      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  practiceLogs   SkillPracticeLog[]

  @@unique([studentId, mathSkillId])
  @@index([studentId, masteryLevel])
  @@index([mathSkillId])
  @@index([studentId, lastPracticeAt])
}

model SkillPracticeLog {
  id              String       @id @default(uuid())
  studentId       String
  mathSkillId     String
  worksheetId     String
  worksheet       Worksheet    @relation(fields: [worksheetId], references: [id])
  worksheetNumber Int
  isTest          Boolean      @default(false)
  score           Float
  rawGrade        Float
  rawOutOf        Float
  previousLevel   MasteryLevel
  newLevel        MasteryLevel
  stabilityAfter  Float
  difficultyAfter Float
  practicedAt     DateTime
  createdAt       DateTime     @default(now())
  masteryRecord   StudentSkillMastery @relation(fields: [studentId, mathSkillId], references: [studentId, mathSkillId])

  @@index([studentId, mathSkillId, practicedAt])
  @@index([worksheetId])
}

enum WorksheetBatchStatus {
  PENDING
  GENERATING_QUESTIONS
  RENDERING_PDFS
  COMPLETED
  FAILED
}

enum GeneratedWorksheetStatus {
  PENDING
  QUESTIONS_READY
  RENDERING
  COMPLETED
  FAILED
}

model QuestionBank {
  id          String    @id @default(uuid())
  mathSkillId String
  mathSkill   MathSkill @relation(fields: [mathSkillId], references: [id])
  question    String
  answer      String
  instruction String
  usedCount   Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([mathSkillId, usedCount])
}

model WorksheetBatch {
  id                  String               @id @default(uuid())
  classId             String
  class               Class                @relation(fields: [classId], references: [id])
  days                Int
  startDate           DateTime
  status              WorksheetBatchStatus @default(PENDING)
  totalWorksheets     Int                  @default(0)
  completedWorksheets Int                  @default(0)
  failedWorksheets    Int                  @default(0)
  pendingSkills       Int                  @default(0)
  completedSkills     Int                  @default(0)
  errors              Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  worksheets          GeneratedWorksheet[]

  @@index([classId])
  @@index([status])
}

model GeneratedWorksheet {
  id             String                   @id @default(uuid())
  studentId      String
  student        User                     @relation(fields: [studentId], references: [id])
  scheduledDate  DateTime
  pdfUrl         String?
  status         GeneratedWorksheetStatus @default(PENDING)
  newSkillId     String
  reviewSkill1Id String
  reviewSkill2Id String
  sectionsJson   Json?
  batchId        String?
  batch          WorksheetBatch?          @relation(fields: [batchId], references: [id])
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  @@index([studentId, scheduledDate])
  @@index([status])
  @@index([batchId, status])
}
